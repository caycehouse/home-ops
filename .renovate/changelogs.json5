{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Point Atuin at its upstream changelog",
      matchPackageNames: ["/atuin/"],
      changelogUrl: "https://github.com/atuinsh/atuin/blob/main/CHANGELOG.md",
    },
    {
      description: "Point TwitchDropsMiner at its upstream changelog",
      matchPackageNames: ["/twitch-drops-miner/"],
      changelogUrl: "https://github.com/fireph/docker-twitch-drops-miner/commits/main",
    },
  ],
}
