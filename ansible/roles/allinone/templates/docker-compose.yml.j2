# {{ ansible_managed }}
---

services:
  atm8:
    image: itzg/minecraft-server:2024.2.2-java8-multiarch@sha256:39becab98460e7cb59951b58433f3bfbbb4d89f15cb024432aa9e66780bced79
    container_name: allinone
    ports:
      - 25567:25565
    environment:
      ALLOW_FLIGHT: "true"
      CF_API_KEY: "{{ cf_api_key }}"
      CF_FILENAME_MATCHER: "1.5.4"
      CF_SLUG: "all-in-one-modded-one-block"
      DIFFICULTY: "hard"
      ENABLE_ROLLING_LOGS: "true"
      EULA: "true"
      FORCE_GAMEMODE: "true"
      MAX_PLAYERS: "10"
      MAX_TICK_TIME: "180000"
      MEMORY: "6G"
      MOTD: "All in One | 1.5.4b"
      OPS: "FryyourBacon"
      OVERRIDE_SERVER_PROPERTIES: "true"
      PUID: "{{ user_id }}"
      PGID: "{{ group_id }}"
      SPAWN_PROTECTION: "0"
      SNOOPER_ENABLED: "false"
      SYNC_CHUNK_WRITES: "false"
      TYPE: "AUTO_CURSEFORGE"
      USE_AIKAR_FLAGS: "true"
      VIEW_DISTANCE: "7"
    tty: true
    stdin_open: true
    networks:
      - default
    volumes:
      - ./data:/data
      - /etc/timezone:/etc/timezone:ro
    healthcheck:
      test: mc-health
      start_period: 7m
      interval: 5s
      retries: 20
    restart: always
    labels:
      # Homepage
      - homepage.group=Games
      - homepage.name=All in One
      - homepage.icon=https://media.forgecdn.net/avatars/342/91/637485703554418199.png
      - homepage.description=Modded One Block
      # AutoKuma
      - kuma.allinone.docker.name=All in One
      - kuma.allinone.docker.docker_container=allinone
      - kuma.allinone.docker.docker_host=1

networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
