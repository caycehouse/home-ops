# {{ ansible_managed }}
---

services:
  atm8:
    image: itzg/minecraft-server:2024.2.2-java17@sha256:cdbc41eb10e56665ee93121a58ec3eccfe9a14b3431b4281a2b3f845e01df67e
    container_name: atm8
    ports:
      - 25570:25565
    environment:
      ALLOW_FLIGHT: "true"
      CF_API_KEY: "{{ cf_api_key }}"
      CF_FILENAME_MATCHER: "1.0.19"
      CF_SLUG: "all-the-mods-8"
      DIFFICULTY: "hard"
      ENABLE_ROLLING_LOGS: "true"
      EULA: "true"
      FORCE_GAMEMODE: "true"
      MAX_PLAYERS: "10"
      MAX_TICK_TIME: "180000"
      MEMORY: "4G"
      MOTD: "All the Mods 8 | 1.0.19b"
      OPS: "FryyourBacon"
      OVERRIDE_SERVER_PROPERTIES: "true"
      PUID: "{{ user_id }}"
      PGID: "{{ group_id }}"
      SPAWN_PROTECTION: "0"
      SNOOPER_ENABLED: "false"
      SIMULATION_DISTANCE: "4"
      SYNC_CHUNK_WRITES: "false"
      TYPE: "AUTO_CURSEFORGE"
      USE_AIKAR_FLAGS: "true"
      VIEW_DISTANCE: "7"
    tty: true
    stdin_open: true
    networks:
      - default
    volumes:
      - ./data:/data
      - /etc/timezone:/etc/timezone:ro
    healthcheck:
      test: mc-health
      start_period: 7m
      interval: 5s
      retries: 20
    restart: always
    labels:
      # Homepage
      - homepage.group=Games
      - homepage.name=All the Mods 8
      - homepage.icon=https://media.forgecdn.net/avatars/902/339/638350403928080320.png
      - homepage.description=All the Mods...again
      # AutoKuma
      - kuma.atm8.docker.name=All the Mods 8
      - kuma.atm8.docker.docker_container=atm8
      - kuma.atm8.docker.docker_host=1

networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
