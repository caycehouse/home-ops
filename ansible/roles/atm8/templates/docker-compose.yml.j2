# {{ ansible_managed }}
---

services:
  atm8:
    image: itzg/minecraft-server:2024.1.0-java17@sha256:ca62acdcdf24be6292da5da92c7d797879c47b93951b40a7f86bfda8d3d2f830
    container_name: atm8
    ports:
      - 25565:25565
    environment:
      ALLOW_FLIGHT: "true"
      CF_API_KEY: "{{ cf_api_key }}"
      CF_FILENAME_MATCHER: "1.0.19"
      CF_SLUG: "all-the-mods-8"
      DIFFICULTY: "hard"
      ENABLE_ROLLING_LOGS: "true"
      EULA: "true"
      FORCE_GAMEMODE: "true"
      MAX_PLAYERS: "10"
      MAX_TICK_TIME: "180000"
      MEMORY: "4G"
      MOTD: "All the Mods 8 | 1.0.19b"
      OPS: "FryyourBacon"
      OVERRIDE_SERVER_PROPERTIES: "true"
      SPAWN_PROTECTION: "0"
      SNOOPER_ENABLED: "false"
      SIMULATION_DISTANCE: "4"
      SYNC_CHUNK_WRITES: "false"
      TYPE: "AUTO_CURSEFORGE"
      USE_AIKAR_FLAGS: "true"
      VIEW_DISTANCE: "7"
    tty: true
    stdin_open: true
    networks:
      - default
    volumes:
      - ./data:/data
      - /etc/timezone:/etc/timezone:ro
    healthcheck:
      test: mc-health
      start_period: 7m
      interval: 5s
      retries: 20
    restart: always
networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
