# {{ ansible_managed }}
---

services:
  cloudflared:
    image: cloudflare/cloudflared:2024.1.5@sha256:76f61aeabe0a968637d67a6bc3e58b4e386996da283f548c7d96dccbf8af0104
    container_name: cloudflared
    command: tunnel --no-autoupdate run
    environment:
      - TUNNEL_TOKEN={{ tunnel_token }}
    networks:
      - tunnel
    restart: unless-stopped
    labels:
      # AutoKuma
      - kuma.cloudflared.docker.name=cloudflared
      - kuma.cloudflared.docker.docker_container=cloudflared
      - kuma.cloudflared.docker.docker_host=1

networks:
  tunnel:
    external: true
