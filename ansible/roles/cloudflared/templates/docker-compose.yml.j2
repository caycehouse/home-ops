# {{ ansible_managed }}
---

services:
  cloudflared:
    image: cloudflare/cloudflared:2024.2.1@sha256:60e94a8669dccbe461b6913ce33ab759104334220b49042ec03cfca62a2f01e7
    container_name: cloudflared
    command: tunnel --no-autoupdate run
    environment:
      - TUNNEL_TOKEN={{ tunnel_token }}
    networks:
      - tunnel
    restart: always
    labels:
      # AutoKuma
      - kuma.cloudflared.docker.name=cloudflared
      - kuma.cloudflared.docker.docker_container=cloudflared
      - kuma.cloudflared.docker.docker_host=1

networks:
  tunnel:
    external: true
