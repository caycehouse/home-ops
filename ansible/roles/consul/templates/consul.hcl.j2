# Full configuration options can be found at https://www.consul.io/docs/agent/config

datacenter = "homelab"
data_dir = "/opt/consul"
bind_addr = "{{ '{{' }} GetInterfaceIP \"tailscale0\" {{ '}}' }}"
retry_join = ["{{ groups['consul_server'] | map('extract', hostvars, ['ansible_tailscale0', 'ipv4', 'address']) | join('\", \"') }}"]
client_addr = "0.0.0.0"

{% if 'consul_server' in group_names %}
server = true
bootstrap_expect = {{ groups['consul_server'] | length }}

ui_config {
    enabled = true
}
{% endif %}

performance {
    raft_multiplier = 1
}

ports {
    grpc = 8502
}
