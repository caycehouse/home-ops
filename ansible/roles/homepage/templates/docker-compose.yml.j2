# {{ ansible_managed }}
---

services:
  homepage:
    container_name: homepage
    image: ghcr.io/gethomepage/homepage:v0.8.6
    volumes:
      - ./app-config:/app/config
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - tunnel
    restart: unless-stopped
networks:
  tunnel:
    external: true
