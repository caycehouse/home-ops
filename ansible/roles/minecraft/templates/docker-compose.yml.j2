# {{ ansible_managed }}
---

services:
  minecraft:
    image: itzg/minecraft-server:2024.2.1-java17@sha256:c000b85f0caf329b0dedae98a415608999e1305fe13489c69e3797f148c472ab
    container_name: minecraft
    ports:
      - 25565:25565
    environment:
      DIFFICULTY: "hard"
      ENABLE_ROLLING_LOGS: "true"
      ENFORCE_WHITELIST: "true"
      EULA: "true"
      FORCE_GAMEMODE: "true"
      MAX_PLAYERS: "10"
      MEMORY: "4G"
      MOTD: "The Fryer's Minecraft Server"
      OPS: "FryyourBacon"
      OVERRIDE_SERVER_PROPERTIES: "true"
      OVERRIDE_WHITELIST: "true"
      PACKWIZ_URL: "https://raw.githubusercontent.com/caycehouse/fabulously-optimized-server/master/pack.toml"
      PUID: "{{ user_id }}"
      PGID: "{{ group_id }}"
      RCON_CMDS_STARTUP: |-
        gamerule doFireTick false
        gamerule playersSleepingPercentage 0
        scoreboard objectives setdisplay list ts_Deaths
      SPAWN_PROTECTION: "0"
      SNOOPER_ENABLED: "false"
      SIMULATION_DISTANCE: "4"
      SYNC_CHUNK_WRITES: "false"
      TYPE: "FABRIC"
      USE_AIKAR_FLAGS: "true"
      VANILLATWEAKS_SHARECODE: "EaW0rS,KR1Q4G"
      VERSION: "1.20.2"
      VIEW_DISTANCE: "7"
      WHITELIST: "FryyourBacon"
    tty: true
    stdin_open: true
    networks:
      - default
    volumes:
      - ./data:/data
      - /etc/timezone:/etc/timezone:ro
    restart: always
    labels:
      # Homepage
      - homepage.group=Games
      - homepage.name=Minecraft
      - homepage.icon=minecraft
      - homepage.description=Vanilla Minecraft server
      # AutoKuma
      - kuma.minecraft.docker.name=Minecraft
      - kuma.minecraft.docker.docker_container=minecraft
      - kuma.minecraft.docker.docker_host=1

networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
