# {{ ansible_managed }}
---

services:
  monica:
    image: monica:4.0.0@sha256:b36452644c7920eac7aedd87e9accb8a76941cf7ca1609c768859d4ac81d8b7c
    container_name: monica
    depends_on:
      - db
    environment:
      APP_ENV: production
      APP_KEY: {{ monica.app_key }}
      DB_HOST: db
      DB_DATABASE: monica
      DB_USERNAME: {{ monica.mysql_user }}
      DB_PASSWORD: {{ monica.mysql_password }}
      LOG_CHANNEL: stderr
      CACHE_DRIVER: database
      SESSION_DRIVER: database
      QUEUE_DRIVER: sync
      MAIL_MAILER: smtp
      MAIL_HOST: smtp.sendgrid.net
      MAIL_PORT: 587
      MAIL_USERNAME: apikey
      MAIL_PASSWORD: {{ monica.mail_password }}
      MAIL_ENCRYPTION: tls
      MAIL_FROM_ADDRESS: no-reply@homelab.caycehouse.com
      MAIL_FROM_NAME: Monica
    volumes:
      - ./var-www-html-storage:/var/www/html/storage
    networks:
      - internal
      - tunnel
    restart: always
    labels:
      # Homepage
      - homepage.group=Utilities
      - homepage.name=Monica
      - homepage.icon=monica
      - homepage.href=https://monica.caycehouse.com
      - homepage.description=Open source personal CRM
      # AutoKuma
      - kuma.monica.docker.name=Monica
      - kuma.monica.docker.docker_container=monica
      - kuma.monica.docker.docker_host=1

  db:
    image: mysql:8.3.0@sha256:053b32141c56632d75405ccdb89a38d04b8f964ec69721fb86f7fa734551cf9c
    environment:
      MYSQL_RANDOM_ROOT_PASSWORD: "true"
      MYSQL_DATABASE: monica
      MYSQL_USER: {{ monica.mysql_user }}
      MYSQL_PASSWORD: {{ monica.mysql_password }}
    volumes:
      - ./var-lib-mysql:/var/lib/mysql
    networks:
      - internal
    restart: always

networks:
  tunnel:
    external: true
  internal:
