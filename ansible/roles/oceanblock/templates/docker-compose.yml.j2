# {{ ansible_managed }}
---

services:
  oceanblock:
    image: itzg/minecraft-server:2024.2.0-java8-multiarch@sha256:96467ca9d0e0d3fa463c1ff4236ff56fc23626ccec0a202210e182f5776c21a7
    container_name: oceanblock
    ports:
      - 25568:25565
    environment:
      DIFFICULTY: "hard"
      ENABLE_ROLLING_LOGS: "true"
      EULA: "TRUE"
      FTB_MODPACK_ID: "91"
      FORCE_GAMEMODE: "true"
      MAX_PLAYERS: "10"
      MEMORY: "4G"
      MOTD: "The Fryer's OceanBlock Server"
      OPS: "FryyourBacon"
      OVERRIDE_SERVER_PROPERTIES: "true"
      PUID: "{{ user_id }}"
      PGID: "{{ group_id }}"
      SNOOPER_ENABLED: "false"
      SYNC_CHUNK_WRITES: "false"
      TYPE: FTBA
      USE_AIKAR_FLAGS: "true"
      VIEW_DISTANCE: "7"
    networks:
      - default
    volumes:
      - ./data:/data
      - /etc/timezone:/etc/timezone:ro
    healthcheck:
      test: mc-health
      start_period: 5m
      interval: 5s
      retries: 20
    restart: always
    labels:
      # Homepage
      - homepage.group=Games
      - homepage.name=OceanBlock
      - homepage.icon=https://www.feed-the-beast.com/_next/image?url=https%3A%2F%2Fapps.modpacks.ch%2Fmodpacks%2Fart%2F87%2Flogo.png&w=256&q=100
      - homepage.description=Time to dive in!
      # AutoKuma
      - kuma.oceanblock.docker.name=OceanBlock
      - kuma.oceanblock.docker.docker_container=oceanblock
      - kuma.oceanblock.docker.docker_host=1

networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
