# {{ ansible_managed }}
---

services:
  broker:
    image: docker.io/library/redis:7@sha256:e647cfe134bf5e8e74e620f66346f93418acfc240b71dd85640325cb7cd01402
    container_name: paperless-ngx_broker
    restart: unless-stopped
    volumes:
      - ./redis-data:/data
    networks:
      - internal

  db:
    image: postgres:16.1@sha256:09f23e02d76670d3b346a3c00aa33a27cf57aab8341eedfcdaed41459d14f5c4
    container_name: paperless-ngx_db
    restart: unless-stopped
    volumes:
      - ./pg-data:/var/lib/postgresql/data
    environment:
      POSTGRES_DB: paperless
      POSTGRES_USER: paperless
      POSTGRES_PASSWORD: paperless
    networks:
      - internal

  paperless-ngx:
    image: ghcr.io/paperless-ngx/paperless-ngx:latest@sha256:13af9a6272ba7558e83a1c294211e3013092e12b6829eafd617a7375bc42a672
    container_name: paperless-ngx
    restart: unless-stopped
    depends_on:
      - db
      - broker
    healthcheck:
      test:
        [
          "CMD",
          "curl",
          "-fs",
          "-S",
          "--max-time",
          "2",
          "http://localhost:8000"
        ]
      interval: 30s
      timeout: 10s
      retries: 5
    volumes:
      - ./data:/usr/src/paperless/data
      - ./media:/usr/src/paperless/media
      - ./export:/usr/src/paperless/export
      - ./consume:/usr/src/paperless/consume
    env_file: docker-compose.env
    environment:
      PAPERLESS_REDIS: redis://broker:6379
      PAPERLESS_DBHOST: db
      USERMAP_UID: "{{ user_id }}"
      USERMAP_GID: "{{ group_id }}"
    networks:
      - tunnel
      - internal
    labels:
      # Homepage
      - homepage.group=Utilities
      - homepage.name=Paperless-ngx
      - homepage.icon=paperless-ngx
      - homepage.href=https://paperless.caycehouse.com
      - homepage.description=Document management system
      # AutoKuma
      - kuma.paperless-ngx.docker.name=Paperless-ngx
      - kuma.paperless-ngx.docker.docker_container=paperless-ngx
      - kuma.paperless-ngx.docker.docker_host=1

networks:
  internal:
  tunnel:
    external: true
