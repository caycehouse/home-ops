# {{ ansible_managed }}
---

services:
  backup:
    image: mazzolino/restic:1.7.1@sha256:d3d2d726434ad92a2cd38de6e1981e74fd969724169bd8bfa38f40b967e9aceb
    container_name: restic-backup
    hostname: "{{ ansible_host }}"
    restart: unless-stopped
    environment:
      RUN_ON_STARTUP: "true"
      BACKUP_CRON: "0 30 3 * * *"
      RESTIC_REPOSITORY: "{{ restic.repository }}"
      RESTIC_PASSWORD: "{{ restic.password }}"
      AWS_ACCESS_KEY_ID: "{{ restic.aws_access_key_id }}"
      AWS_SECRET_ACCESS_KEY: "{{ restic.aws_secret_access_key }}"
      TZ: America/New_York
    volumes:
      - /home/caycehouse:/data:ro
    labels:
      # AutoKuma
      - kuma.restic-backup.docker.name=Restic
      - kuma.restic-backup.docker.docker_container=restic-backup
      - kuma.restic-backup.docker.docker_host=1

{% if ansible_host == "bakery" %}
  prune:
    image: mazzolino/restic:1.7.1@sha256:d3d2d726434ad92a2cd38de6e1981e74fd969724169bd8bfa38f40b967e9aceb
    container_name: restic-prune
    hostname: "{{ ansible_host }}"
    restart: unless-stopped
    environment:
      RUN_ON_STARTUP: "true"
      PRUNE_CRON: "0 0 4 * * *"
      RESTIC_FORGET_ARGS: >-
        --prune --keep-last 1 --keep-daily 7 --keep-monthly 12
      RESTIC_REPOSITORY: "{{ restic.repository }}"
      RESTIC_PASSWORD: "{{ restic.password }}"
      AWS_ACCESS_KEY_ID: "{{ restic.aws_access_key_id }}"
      AWS_SECRET_ACCESS_KEY: "{{ restic.aws_secret_access_key }}"
      TZ: America/New_York

  check:
    image: mazzolino/restic:1.7.1@sha256:d3d2d726434ad92a2cd38de6e1981e74fd969724169bd8bfa38f40b967e9aceb
    container_name: restic-cron
    hostname: "{{ ansible_host }}"
    restart: unless-stopped
    environment:
      RUN_ON_STARTUP: "false"
      CHECK_CRON: "0 15 5 * * *"
      RESTIC_CHECK_ARGS: >-
        --read-data-subset=10%
      RESTIC_REPOSITORY: "{{ restic.repository }}"
      RESTIC_PASSWORD: "{{ restic.password }}"
      AWS_ACCESS_KEY_ID: "{{ restic.aws_access_key_id }}"
      AWS_SECRET_ACCESS_KEY: "{{ restic.aws_secret_access_key }}"
      TZ: America/New_York
{% endif %}
