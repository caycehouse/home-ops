# {{ ansible_managed }}
---

services:
  thethans:
    image: itzg/minecraft-server:2024.2.0-java17@sha256:357ba71de8076057abe78123a694c5d37eb1e0c92d3762f19a64162b41586734
    container_name: thethans
    ports:
      - 25569:25565
    environment:
      DIFFICULTY: "hard"
      ENABLE_ROLLING_LOGS: "true"
      ENFORCE_WHITELIST: "true"
      EULA: "true"
      FORCE_GAMEMODE: "true"
      MAX_PLAYERS: "10"
      MEMORY: "4G"
      MOTD: "Thethan's Minecraft Server"
      OPS: "EthanKruse,0_Burnt_Toast_0"
      OVERRIDE_SERVER_PROPERTIES: "true"
      OVERRIDE_WHITELIST: "true"
      RCON_CMDS_STARTUP: |-
        gamerule doFireTick false
        gamerule playersSleepingPercentage 0
      SPAWN_PROTECTION: "0"
      SNOOPER_ENABLED: "false"
      SIMULATION_DISTANCE: "10"
      SYNC_CHUNK_WRITES: "false"
      USE_AIKAR_FLAGS: "true"
      VIEW_DISTANCE: "10"
      WHITELIST: "EthanKruse,0_Burnt_Toast_0,FryyourBacon"
    labels:
      - homepage.group=Games
      - homepage.name=TheThans
      - homepage.icon=minecraft
      - homepage.description=Vanilla Minecraft server
    tty: true
    stdin_open: true
    volumes:
      - ./data:/data
      - /etc/timezone:/etc/timezone:ro
    restart: always
