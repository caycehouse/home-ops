# {{ ansible_managed }}
---

services:
  twitchdropsminer:
    image: ghcr.io/valentin-metz/twitchdropsminer:master@sha256:67c88d1d8bde6fb347a4160041d77c22de1fe8399a283413ef8a9b09c5b2b57c
    container_name: twitchdropsminer
    volumes:
      - ./cookies.jar:/TwitchDropsMiner/cookies.jar
      - ./settings.json:/TwitchDropsMiner/settings.json:ro
    restart: unless-stopped
    tty: true
    stdin_open: true
    labels:
      # Homepage
      - homepage.group=Utilities
      - homepage.name=TwitchDropsMiner
      - homepage.icon=mdi-twitch
      - homepage.description=AFK Twitch drops miner
      # AutoKuma
      - kuma.twitchdropsminer.docker.name=TwitchDropsMiner
      - kuma.twitchdropsminer.docker.docker_container=twitchdropsminer
      - kuma.twitchdropsminer.docker.docker_host=1
