{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "default:automergeBranch",
    "default:automergeDigest",
    "docker:enableMajor",
    "docker:pinDigests"
  ],
  "docker-compose": {
    "fileMatch": [
      "(^|/)(?:docker-)?compose[^/]*\\.ya?ml.j2$"
    ]
  }
}
