# {{ ansible_managed }}
---

services:
  atm8:
    image: itzg/minecraft-server:java17@sha256:43dd0c61ef073fdea88605326ccc5b4674dee2cf7404811206863e07eeb61efc
    container_name: atm8
    ports:
      - 25565:25565
    environment:
      EULA: "TRUE"
      CF_PAGE_URL: https://www.curseforge.com/minecraft/modpacks/all-the-mods-8
      CF_FILENAME_MATCHER: "1.0.13"
      MEMORY: "4G"
      TYPE: AUTO_CURSEFORGE
      USE_AIKAR_FLAGS: "true"
    networks:
      - default
    volumes:
      - ./data:/data
    healthcheck:
      test: mc-health
      start_period: 7m
      interval: 5s
      retries: 20
    restart: always
networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
