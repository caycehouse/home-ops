# {{ ansible_managed }}
---

services:
  cloudflared:
    image: cloudflare/cloudflared:2023.7.0@sha256:e66b89b36075068929e08bbd7e257979d973ba51439200dc1e6227aa022b71bd
    command: tunnel --no-autoupdate run
    environment:
      - TUNNEL_TOKEN={{ tunnel_token }}
    networks:
      - tunnel
    restart: unless-stopped
networks:
  tunnel:
    external: true
