# {{ ansible_managed }}
---

services:
  cloudflared:
    image: cloudflare/cloudflared:2023.7.3@sha256:1278c07596b20154931dbf09c26ea8006276ed5444496c5892705fc3accb3cca
    command: tunnel --no-autoupdate run
    environment:
      - TUNNEL_TOKEN={{ tunnel_token }}
    networks:
      - tunnel
    restart: unless-stopped
networks:
  tunnel:
    external: true
