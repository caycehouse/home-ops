# {{ ansible_managed }}
---

services:
  cloudflared:
    image: cloudflare/cloudflared:2023.6.0@sha256:c6ef21fdafda34117ffa741aa163ce6bb834e25e041fab8dae55f200fe5b9288
    command: tunnel --no-autoupdate run
    environment:
      - TUNNEL_TOKEN={{ tunnel_token }}
    networks:
      - tunnel
networks:
  tunnel:
    external: true
