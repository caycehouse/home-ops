# {{ ansible_managed }}
---

services:
  cloudflared:
    image: cloudflare/cloudflared:2023.8.1@sha256:41d92f563f1ae7248014791fe67d67e0ea1558ad070160b26e43d8ee262a2daf
    command: tunnel --no-autoupdate run
    environment:
      - TUNNEL_TOKEN={{ tunnel_token }}
    networks:
      - tunnel
    restart: unless-stopped
networks:
  tunnel:
    external: true
