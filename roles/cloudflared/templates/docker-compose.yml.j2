# {{ ansible_managed }}
---

services:
  cloudflared:
    image: cloudflare/cloudflared:2023.8.0@sha256:22e278ca91dc905ebf582c04ccc9db7f559114067ab36f83262c287340b6ce51
    command: tunnel --no-autoupdate run
    environment:
      - TUNNEL_TOKEN={{ tunnel_token }}
    networks:
      - tunnel
    restart: unless-stopped
networks:
  tunnel:
    external: true
