# {{ ansible_managed }}
---

services:
  code-server:
    image: lscr.io/linuxserver/code-server:4.11.0@sha256:35c6da4e9d6cd623b7bb6a92b4a3fe1b62b778bd0b49ef16b9cae951ad4a8963
    environment:
      DOCKER_MODS: linuxserver/mods:code-server-python3
      PGID: 1002
      PUID: 1002
      SUDO_PASSWORD: "{{ code_server.sudo_password }}"
      TZ: America/New_York
    volumes:
      - ./config:/config
      - /dev/net/tun:/dev/net/tun
    networks:
      - traefik_public
    cap_add:
      - NET_ADMIN
    labels:
      - "traefik.docker.network=traefik_public"
      - "traefik.http.routers.code-server.rule=Host(`code-server.caycehouse.com`)"
      - "traefik.http.routers.code-server.entrypoints=websecure"
      - "traefik.http.services.code-server.loadbalancer.server.port=8443"
      - "traefik.enable=true"
networks:
  traefik_public:
    external: true
