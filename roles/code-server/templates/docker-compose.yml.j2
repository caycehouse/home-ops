# {{ ansible_managed }}
---

services:
  code-server:
    image: lscr.io/linuxserver/code-server:4.20.1@sha256:894e4bbbb876e64f170938ae2b23de95b55d28f90a4eae064d9a0a5e109bd927
    environment:
      DOCKER_MODS: linuxserver/mods:code-server-python3
      PGID: 1002
      PUID: 1002
      SUDO_PASSWORD: "{{ code_server.sudo_password }}"
      TZ: America/New_York
    volumes:
      - ./config:/config
      - /dev/net/tun:/dev/net/tun
    networks:
      - tunnel
    cap_add:
      - NET_ADMIN
networks:
  tunnel:
    external: true
