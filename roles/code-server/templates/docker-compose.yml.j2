# {{ ansible_managed }}
---

services:
  code-server:
    image: lscr.io/linuxserver/code-server:4.16.1@sha256:940c4497926593996bad115a4bd9896b95b5d9f36c7feb2108c5b313b1a5aa5a
    environment:
      DOCKER_MODS: linuxserver/mods:code-server-python3
      PGID: 1002
      PUID: 1002
      SUDO_PASSWORD: "{{ code_server.sudo_password }}"
      TZ: America/New_York
    volumes:
      - ./config:/config
      - /dev/net/tun:/dev/net/tun
    networks:
      - tunnel
    cap_add:
      - NET_ADMIN
networks:
  tunnel:
    external: true
