# Full configuration options can be found at https://www.consul.io/docs/agent/config

datacenter = "homelab"
data_dir = "/opt/consul"
bind_addr = "{{ '{{' }} GetInterfaceIP \"tailscale0\" {{ '}}' }}"
encrypt = "{{ consul_gossip_encryption_key }}"
retry_join = ["{{ hostvars['dingdongs']['ansible_facts']['tailscale0']['ipv4']['address'] }}"]
client_addr = "0.0.0.0"

{% if 'consul_server' in group_names %}
server = true
bootstrap_expect = {{ groups['consul_server'] | length }}

ui_config {
  enabled = true
}
{% endif %}

auto_encrypt {
    {% if 'consul_server' in group_names %}
    allow_tls = true
    {% else %}
    tls = true
    {% endif %}
}

tls {
    defaults {
        {% if 'consul_server' in group_names %}
        cert_file = "/etc/consul.d/homelab-server-consul-0.pem"
        key_file = "/etc/consul.d/homelab-server-consul-0-key.pem"
        {% endif %}
        ca_file = "/etc/consul.d/consul-agent-ca.pem"
        verify_incoming = true
        verify_outgoing = true
    }

    internal_rpc {
        verify_server_hostname = true
    }
}

performance {
  raft_multiplier = 1
}

acl {
  enabled = true
  default_policy = "allow"
  enable_token_persistence = true
}
