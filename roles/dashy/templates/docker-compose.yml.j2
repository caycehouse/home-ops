# {{ ansible_managed }}
---

services:
  dashy:
    image: lissy93/dashy:2.1.1@sha256:ca1497c7c12eee2c1d599945e04e87ed0f2e40728441694dbca8f435e8da0146
    container_name: Dashy
    volumes:
      - ./app-public:/app/public
    networks:
      - tunnel
    environment:
      - NODE_ENV=production
      - UID=1002
      - GID=1002
    restart: always
    healthcheck:
      test: [ 'CMD', 'node', '/app/services/healthcheck' ]
      interval: 1m30s
      timeout: 10s
      retries: 3
      start_period: 40s
networks:
  tunnel:
    external: true
