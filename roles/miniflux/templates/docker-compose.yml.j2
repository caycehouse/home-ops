# {{ ansible_managed }}
---

services:
  miniflux:
    image: miniflux/miniflux:2.0.43-distroless@sha256:203aa96b3e120d00faceee0698feb9cb2c8aa9a6082bfe8a5170327dbe45dcd9
    container_name: miniflux
    depends_on:
      db:
        condition: service_healthy
    environment:
      DATABASE_URL: postgres://{{ miniflux.postgres_user }}:{{ miniflux.postgres_password }}@db/miniflux?sslmode=disable
      RUN_MIGRATIONS: 1
      CREATE_ADMIN: 1
      ADMIN_USERNAME: {{ miniflux.admin_username }}
      ADMIN_PASSWORD: {{ miniflux.admin_password }}
    healthcheck:
      test: [ "CMD", "/usr/bin/miniflux", "-healthcheck", "auto" ]
    networks:
      - internal
      - traefik_public
    labels:
      - "traefik.docker.network=traefik_public"
      - "traefik.http.routers.miniflux.rule=Host(`rss.caycehouse.com`)"
      - "traefik.http.routers.miniflux.entrypoints=websecure"
      - "traefik.http.services.miniflux.loadbalancer.server.port=8080"
      - "traefik.enable=true"
    restart: always
  db:
    image: postgres:15@sha256:6cc97262444f1c45171081bc5a1d4c28b883ea46a6e0d1a45a8eac4a7f4767ab
    container_name: postgres
    environment:
      POSTGRES_USER: {{ miniflux.postgres_user }}
      POSTGRES_PASSWORD: {{ miniflux.postgres_password }}
    volumes:
      - ./var-lib-postgresql-data:/var/lib/postgresql/data
    healthcheck:
      test: [ "CMD", "pg_isready", "-U", "miniflux" ]
      interval: 10s
      start_period: 30s
    networks:
      - internal
    restart: always
networks:
  traefik_public:
    external: true
  internal:
