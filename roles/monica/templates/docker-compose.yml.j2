# {{ ansible_managed }}
---

services:
  monica:
    image: monica:4.0.0@sha256:407a5c4a1dca845fd4b9782e53fc1baa54216ffbfbaa1fef8ddf71a229235e2a
    depends_on:
      - db
    environment:
      APP_ENV: production
      APP_KEY: {{ monica.app_key }}
      DB_HOST: db
      DB_DATABASE: monica
      DB_USERNAME: {{ monica.mysql_user }}
      DB_PASSWORD: {{ monica.mysql_password }}
      LOG_CHANNEL: stderr
      CACHE_DRIVER: database
      SESSION_DRIVER: database
      QUEUE_DRIVER: sync
      MAIL_MAILER: smtp
      MAIL_HOST: smtp.sendgrid.net
      MAIL_PORT: 587
      MAIL_USERNAME: apikey
      MAIL_PASSWORD: {{ monica.mail_password }}
      MAIL_ENCRYPTION: tls
      MAIL_FROM_ADDRESS: no-reply@homelab.caycehouse.com
      MAIL_FROM_NAME: Monica
    volumes:
      - ./var-www-html-storage:/var/www/html/storage
    networks:
      - internal
      - tunnel
    restart: always
  db:
    image: mysql:8.2.0@sha256:1773f3c7aa9522f0014d0ad2bbdaf597ea3b1643c64c8ccc2123c64afd8b82b1
    environment:
      MYSQL_RANDOM_ROOT_PASSWORD: "true"
      MYSQL_DATABASE: monica
      MYSQL_USER: {{ monica.mysql_user }}
      MYSQL_PASSWORD: {{ monica.mysql_password }}
    volumes:
      - ./var-lib-mysql:/var/lib/mysql
    networks:
      - internal
    restart: always
networks:
  tunnel:
    external: true
  internal:
