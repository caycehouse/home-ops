# Full configuration options can be found at https://www.nomadproject.io/docs/configuration

datacenter = "homelab"
data_dir  = "/opt/nomad/data"
bind_addr = "0.0.0.0"

advertise {
  http = "{{ '{{' }} GetInterfaceIP \"tailscale0\" {{ '}}' }}"
  rpc  = "{{ '{{' }} GetInterfaceIP \"tailscale0\" {{ '}}' }}"
  serf = "{{ '{{' }} GetInterfaceIP \"tailscale0\" {{ '}}' }}"
}

{% if 'nomad_server' in group_names %}
server {
  enabled          = true
  bootstrap_expect = {{ groups['nomad_server'] | length }}
}
{% endif %}

client {
  enabled = true
  network_interface = "tailscale0"
}

tls {
  http = true
  rpc  = true

  ca_file   = "/etc/nomad.d/nomad-ca.pem"
{% if 'nomad_server' in group_names %}
  cert_file = "/etc/nomad.d/server.pem"
  key_file  = "/etc/nomad.d/server-key.pem"
{% else %}
  cert_file = "/etc/nomad.d/client.pem"
  key_file  = "/etc/nomad.d/client-key.pem"
{% endif %}

  verify_server_hostname = true
  verify_https_client    = false
}

plugin "docker" {
  config {
    volumes {
      enabled = true
    }
  }
}
