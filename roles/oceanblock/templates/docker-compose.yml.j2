# {{ ansible_managed }}
---

services:
  oceanblock:
    image: itzg/minecraft-server:2023.3.0-java8-multiarch@sha256:4bb92a7fc699559aef61e27a7da8f5d1446b84fb89ed1aebe2d22109bcbafb56
    container_name: oceanblock
    ports:
      - 25565:25565
    environment:
      EULA: "TRUE"
      FTB_MODPACK_ID: "91"
      FTB_MODPACK_VERSION_ID: "2245"
      MEMORY: "4G"
      TYPE: FTBA
      USE_AIKAR_FLAGS: "true"
    networks:
      - default
    volumes:
      - ./data:/data
    healthcheck:
      test: mc-health
      start_period: 5m
      interval: 5s
      retries: 20
    restart: always
networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
