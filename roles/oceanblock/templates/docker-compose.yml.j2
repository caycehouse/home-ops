# {{ ansible_managed }}
---

services:
  oceanblock:
    image: itzg/minecraft-server:2023.4.1-java8-multiarch@sha256:52843b7501e8ed1020386d5cd75ce06e815916fe361da757d378abbcf3270088
    container_name: oceanblock
    ports:
      - 25565:25565
    environment:
      EULA: "TRUE"
      FTB_MODPACK_ID: "91"
      FTB_MODPACK_VERSION_ID: "2245"
      MEMORY: "4G"
      TYPE: FTBA
      USE_AIKAR_FLAGS: "true"
    networks:
      - default
    volumes:
      - ./data:/data
    healthcheck:
      test: mc-health
      start_period: 5m
      interval: 5s
      retries: 20
    restart: always
networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
