# {{ ansible_managed }}
---

services:
  plexiglass-mountain:
    image: itzg/minecraft-server:2023.7.0-java17@sha256:e43c82f57881d188c7057d4aedda0dd49d9fa5efaaf2adabc02661a463c91aa1
    container_name: plexiglass-mountain
    ports:
      - 25566:25565
    environment:
      ALLOW_FLIGHT: "true"
      DIFFICULTY: "hard"
      ENABLE_ROLLING_LOGS: "true"
      ENFORCE_WHITELIST: "true"
      EULA: "true"
      FORCE_GAMEMODE: "true"
      FTB_MODPACK_ID: "96"
      MAX_PLAYERS: "10"
      MEMORY: "4G"
      MOTD: "The Fryer's Plexiglass Mountain Server"
      OPS: "FryyourBacon"
      OVERRIDE_SERVER_PROPERTIES: "true"
      OVERRIDE_WHITELIST: "true"
      SIMULATION_DISTANCE: "4"
      SNOOPER_ENABLED: "false"
      SPAWN_PROTECTION: "0"
      SYNC_CHUNK_WRITES: "false"
      TYPE: "FTBA"
      USE_AIKAR_FLAGS: "true"
      VIEW_DISTANCE: "7"
      WHITELIST: "FryyourBacon"
    tty: true
    stdin_open: true
    networks:
      - default
    volumes:
      - ./data:/data
      - /etc/timezone:/etc/timezone:ro
    healthcheck:
      test: mc-health
      start_period: 7m
      interval: 5s
      retries: 20
    restart: always
networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
