# {{ ansible_managed }}
---

services:
  portainer_agent:
    image: portainer/agent:2.17.1-alpine@sha256:572bdb97113b64d4fd0eb37528814480b4c0169c02044335c63c9cd44f2c25c5
    container_name: portainer_agent
    volumes:
      - /var/lib/docker/volumes:/var/lib/docker/volumes
      - /var/run/docker.sock:/var/run/docker.sock
    ports:
      - 9001:9001
    networks:
      - default
    restart: always
networks:
  default:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
