# {{ ansible_managed }}
---

services:
  portainer_agent:
    image: portainer/agent:2.19.4-alpine@sha256:565cab16a8ffe05b10810871ec81f0a7a81f140780fed5c0cb70dba230335c72
    container_name: portainer_agent
    volumes:
      - /var/lib/docker/volumes:/var/lib/docker/volumes
      - /var/run/docker.sock:/var/run/docker.sock
    ports:
      - 9001:9001
    networks:
      - internal
    restart: always
networks:
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
