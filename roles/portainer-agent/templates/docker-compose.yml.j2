# {{ ansible_managed }}
---

services:
  portainer_agent:
    image: portainer/agent:2.18.1-alpine@sha256:4bde0d70ba27e4f6e2b10ea390b4e01f073ef2a3f0d9819cbaf2cc05da597b09
    container_name: portainer_agent
    volumes:
      - /var/lib/docker/volumes:/var/lib/docker/volumes
      - /var/run/docker.sock:/var/run/docker.sock
    ports:
      - 9001:9001
    networks:
      - default
    restart: always
networks:
  default:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
