# {{ ansible_managed }}
---

services:
  portainer_agent:
    image: portainer/agent:2.19.1-alpine@sha256:08446cc8c3c555a4f818f72a8abf465b11f6dfafa6d1fdd6ae77b3c4a408fe4c
    container_name: portainer_agent
    volumes:
      - /var/lib/docker/volumes:/var/lib/docker/volumes
      - /var/run/docker.sock:/var/run/docker.sock
    ports:
      - 9001:9001
    networks:
      - internal
    restart: always
networks:
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
