# {{ ansible_managed }}
---

services:
  portainer_agent:
    image: portainer/agent:2.19.0-alpine@sha256:dcd7596316d5c29ad9df032abca0cfe5c47acb377ec7c33aafb68cf99fde85c8
    container_name: portainer_agent
    volumes:
      - /var/lib/docker/volumes:/var/lib/docker/volumes
      - /var/run/docker.sock:/var/run/docker.sock
    ports:
      - 9001:9001
    networks:
      - internal
    restart: always
networks:
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
