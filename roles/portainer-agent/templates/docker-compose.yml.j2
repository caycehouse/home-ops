# {{ ansible_managed }}
---

services:
  portainer_agent:
    image: portainer/agent:2.18.2-alpine
    container_name: portainer_agent
    volumes:
      - /var/lib/docker/volumes:/var/lib/docker/volumes
      - /var/run/docker.sock:/var/run/docker.sock
    ports:
      - 9001:9001
    networks:
      - internal
    restart: always
networks:
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
