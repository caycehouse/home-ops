# {{ ansible_managed }}
---

services:
  portainer_agent:
    image: portainer/agent:2.19.3-alpine@sha256:7c4cd6114ab426e81445b448e73461e01447d1e8911a19f476239370028456de
    container_name: portainer_agent
    volumes:
      - /var/lib/docker/volumes:/var/lib/docker/volumes
      - /var/run/docker.sock:/var/run/docker.sock
    ports:
      - 9001:9001
    networks:
      - internal
    restart: always
networks:
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
