# {{ ansible_managed }}
---

services:
  portainer_agent:
    image: portainer/agent:2.18.4-alpine@sha256:fb01e14dfc24c0aa21ea0a95bb2dca1d7b8f3641fbd4b0d4b8a16da513482127
    container_name: portainer_agent
    volumes:
      - /var/lib/docker/volumes:/var/lib/docker/volumes
      - /var/run/docker.sock:/var/run/docker.sock
    ports:
      - 9001:9001
    networks:
      - internal
    restart: always
networks:
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
