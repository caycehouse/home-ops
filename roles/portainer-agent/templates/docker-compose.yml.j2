# {{ ansible_managed }}
---

services:
  portainer_agent:
    image: portainer/agent:2.19.2-alpine@sha256:67554523ad064b0f4308392a520c91f350df8db5f53aae851af48a66a3e1d2d6
    container_name: portainer_agent
    volumes:
      - /var/lib/docker/volumes:/var/lib/docker/volumes
      - /var/run/docker.sock:/var/run/docker.sock
    ports:
      - 9001:9001
    networks:
      - internal
    restart: always
networks:
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
