# {{ ansible_managed }}
---

services:
  portainer:
    image: portainer/portainer-ce:2.18.2-alpine
    container_name: portainer
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./data:/data
    ports:
      - "9443:9443"
    networks:
      - internal
      - tunnel
    restart: always
networks:
  tunnel:
    external: true
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
