# {{ ansible_managed }}
---

services:
  portainer:
    image: portainer/portainer-ce:2.18.1-alpine@sha256:0b8677192fd6c3307d157624a4293ae79899992b74e4c892926e6924ceb7f7bc
    container_name: portainer
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./data:/data
    ports:
      - "9443:9443"
    networks:
      - default
      - traefik_public
    labels:
      - traefik.docker.network=traefik_public
      - traefik.enable=true
      - traefik.http.routers.portainer.entrypoints=websecure
      - traefik.http.routers.portainer.rule=Host(`portainer.caycehouse.com`)
      - traefik.http.services.portainer.loadbalancer.server.port=9000
    restart: always
networks:
  traefik_public:
    external: true
  default:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
