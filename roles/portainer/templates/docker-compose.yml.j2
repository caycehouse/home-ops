# {{ ansible_managed }}
---

services:
  portainer:
    image: portainer/portainer-ce:2.19.2-alpine@sha256:10cf26e05c98f73127384f3d974eb5015c4b7a349ccbe7814bc5e1fe6ed71cbf
    container_name: portainer
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./data:/data
    ports:
      - "9443:9443"
    networks:
      - internal
      - tunnel
    restart: always
networks:
  tunnel:
    external: true
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
