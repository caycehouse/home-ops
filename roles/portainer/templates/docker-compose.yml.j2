# {{ ansible_managed }}
---

services:
  portainer:
    image: portainer/portainer-ce:2.18.2-alpine@sha256:790b0eede06acefcd44366e44b651b4e55818dcae3081598d0a125aae12f3397
    container_name: portainer
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./data:/data
    ports:
      - "9443:9443"
    networks:
      - default
      - traefik_public
    labels:
      - traefik.docker.network=traefik_public
      - traefik.enable=true
      - traefik.http.routers.portainer.entrypoints=websecure
      - traefik.http.routers.portainer.rule=Host(`portainer.caycehouse.com`)
      - traefik.http.services.portainer.loadbalancer.server.port=9000
    restart: always
networks:
  traefik_public:
    external: true
  default:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
