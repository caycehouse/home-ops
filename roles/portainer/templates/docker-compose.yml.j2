# {{ ansible_managed }}
---

services:
  portainer:
    image: portainer/portainer-ce:2.19.0-alpine@sha256:c4dc36228b8809a21b8c809e780a6d66744455c032443368d95a8797a7d7afea
    container_name: portainer
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./data:/data
    ports:
      - "9443:9443"
    networks:
      - internal
      - tunnel
    restart: always
networks:
  tunnel:
    external: true
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
