# {{ ansible_managed }}
---

services:
  portainer:
    image: portainer/portainer-ce:2.18.2-alpine@sha256:790b0eede06acefcd44366e44b651b4e55818dcae3081598d0a125aae12f3397
    container_name: portainer
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./data:/data
    ports:
      - "9443:9443"
    networks:
      - internal
      - tunnel
    restart: always
networks:
  tunnel:
    external: true
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
