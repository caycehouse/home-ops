# {{ ansible_managed }}
---

services:
  portainer:
    image: portainer/portainer-ce:2.18.3-alpine@sha256:ff23e6913f3bd8c91cd8ad8f211ef8ac61f04e0b0cba7fb10cc20ee5c15bcc49
    container_name: portainer
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./data:/data
    ports:
      - "9443:9443"
    networks:
      - internal
      - tunnel
    restart: always
networks:
  tunnel:
    external: true
  internal:
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: 1280
