# {{ ansible_managed }}
---

services:
  satisfactory:
    image: wolveix/satisfactory-server:v1.5.4@sha256:3078febb3f1f70b8172a85dc6e401450112ef06a05ec3d360e34af26c2e30961
    container_name: satisfactory
    environment:
      AUTOPAUSE: "false"
      PGID: 1000
      PUID: 1000
    networks:
      - internal
    volumes:
      - ./config-backups:/config/backups
      - ./config-saved:/config/saved
      - satisfactory:/config/gamefiles
    ports:
      - 7777:7777/udp
      - 15000:15000/udp
      - 15777:15777/udp
    restart: always
networks:
  internal:
    driver_opts:
      com.docker.network.driver.mtu: 1280
volumes:
  satisfactory:
