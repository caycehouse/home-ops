# {{ ansible_managed }}
---

services:
  satisfactory:
    image: wolveix/satisfactory-server:v1.5.6@sha256:77bbd2eed50fbf49114dcce090a71a07933a7496787f07bfc947fb6fc5367efa
    container_name: satisfactory
    environment:
      AUTOPAUSE: "false"
      PGID: 1000
      PUID: 1000
    networks:
      - internal
    volumes:
      - ./config-backups:/config/backups
      - ./config-saved:/config/saved
      - satisfactory:/config/gamefiles
    ports:
      - 7777:7777/udp
      - 15000:15000/udp
      - 15777:15777/udp
    restart: always
networks:
  internal:
    driver_opts:
      com.docker.network.driver.mtu: 1280
volumes:
  satisfactory:
