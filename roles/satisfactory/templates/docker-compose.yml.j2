# {{ ansible_managed }}
---

services:
  satisfactory:
    image: wolveix/satisfactory-server:v1.4.8@sha256:56ca73cb8a64e7bedfe0b72c9490ce1d32e547a16c753ffcb7e96c8364e8c348
    container_name: satisfactory
    environment:
      AUTOPAUSE: "false"
      PGID: 1000
      PUID: 1000
    networks:
      - internal
    volumes:
      - ./config-backups:/config/backups
      - ./config-saved:/config/saved
      - satisfactory:/config/gamefiles
    ports:
      - 7777:7777/udp
      - 15000:15000/udp
      - 15777:15777/udp
    restart: always
networks:
  internal:
    driver_opts:
      com.docker.network.driver.mtu: 1280
volumes:
  satisfactory:
