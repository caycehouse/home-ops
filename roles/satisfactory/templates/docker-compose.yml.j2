# {{ ansible_managed }}
---

services:
  satisfactory:
    image: wolveix/satisfactory-server:v1.5.5@sha256:d11aa182cf270463c3f75e22425522e78dceff24de9e4794cae2591eeaada8ca
    container_name: satisfactory
    environment:
      AUTOPAUSE: "false"
      PGID: 1000
      PUID: 1000
    networks:
      - internal
    volumes:
      - ./config-backups:/config/backups
      - ./config-saved:/config/saved
      - satisfactory:/config/gamefiles
    ports:
      - 7777:7777/udp
      - 15000:15000/udp
      - 15777:15777/udp
    restart: always
networks:
  internal:
    driver_opts:
      com.docker.network.driver.mtu: 1280
volumes:
  satisfactory:
