# {{ ansible_managed }}
---

services:
  thethans:
    image: itzg/minecraft-server:2023.3.0-java17@sha256:b29bd721ad60be3ad71fc7f88c4999e89f72bd63c3af528da525544f91cfb848
    container_name: thethans
    ports:
      - 25566:25565
    environment:
      DIFFICULTY: hard
      ENABLE_ROLLING_LOGS: "true"
      EULA: "true"
      FORCE_GAMEMODE: "true"
      MAX_PLAYERS: 10
      MEMORY: 4G
      MOTD: Thethan's Minecraft Server
      OPS: EthanKruse,0_Burnt_Toast_0
      OVERRIDE_SERVER_PROPERTIES: "true"
      RCON_CMDS_STARTUP: |-
        gamerule doFireTick false
        gamerule playersSleepingPercentage 0
      SPAWN_PROTECTION: 0
      SNOOPER_ENABLED: "false"
      SIMULATION_DISTANCE: 10
      SYNC_CHUNK_WRITES: "false"
      USE_AIKAR_FLAGS: "true"
      VIEW_DISTANCE: 10
    tty: true
    stdin_open: true
    volumes:
      - ./data:/data
      - /etc/timezone:/etc/timezone:ro
    restart: always
