# {{ ansible_managed }}
---

services:
  valheim:
    image: ghcr.io/lloesche/valheim-server:latest@sha256:1d77b729af5d20c34489d8774e504441a528dad8ed80bb7b469c3d2d9dcd8de5
    cap_add:
      - sys_nice
    container_name: valheim
    environment:
      SERVER_NAME: "The Fryer's Valheim Server"
      SERVER_PASS: "{{ valheim.server_pass }}"
      TZ: America/New_York
    networks:
      - default
    volumes:
      - ./config:/config
      - valheim:/opt/valheim
    ports:
      - "2456-2457:2456-2457/udp"
    stop_grace_period: 2m
    restart: always
networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
volumes:
  valheim:
