# {{ ansible_managed }}
---

services:
  valheim:
    image: ghcr.io/lloesche/valheim-server:latest@sha256:65fcb2c995651a89433485b2b570ae9b66d60f6a0451d07e251b6be2e75b880f
    cap_add:
      - sys_nice
    container_name: valheim
    environment:
      SERVER_NAME: "The Fryer's Valheim Server"
      SERVER_PASS: "{{ valheim.server_pass }}"
      TZ: America/New_York
    networks:
      - default
    volumes:
      - ./config:/config
      - ./opt-valheim:/opt/valheim
    ports:
      - "2456-2457:2456-2457/udp"
    stop_grace_period: 2m
    restart: always
networks:
  default:
    driver_opts:
      com.docker.network.driver.mtu: 1280
