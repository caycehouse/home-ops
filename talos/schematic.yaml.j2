---
customization:
  extraKernelArgs:
    - i915.enable_guc=2 # Comet Lake CPU & Intel iGPU
    - intel_iommu=on # PCI Passthrough
    - iommu=pt # PCI Passthrough
  systemExtensions:
    officialExtensions:
      - siderolabs/i915 # Intel iGPU
      - siderolabs/intel-ucode # Intel iGPU
      - siderolabs/mei # Intel iGPU
      - siderolabs/realtek-firmware # Realtek NICs
      - siderolabs/zfs # ZFS for OpenEBS zfs-localpv (single-node local storage)
